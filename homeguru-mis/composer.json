{
    "name": "homeguru/mis",
    "description": "HomeGuru Management Information System",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "HomeGuru Team",
            "email": "dev@homeguru.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "firebase/php-jwt": "^6.0",
        "phpmailer/phpmailer": "^6.8",
        "twilio/sdk": "^6.0",
        "razorpay/razorpay": "^2.8",
        "stripe/stripe-php": "^10.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "tecnickcom/tcpdf": "^6.6",
        "endroid/qr-code": "^4.6",
        "monolog/monolog": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "ramsey/uuid": "^4.7",
        "intervention/image": "^2.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mockery/mockery": "^1.5",
        "fakerphp/faker": "^1.21"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "post-install-cmd": [
            "php scripts/install.php"
        ],
        "post-update-cmd": [
            "php scripts/update.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}